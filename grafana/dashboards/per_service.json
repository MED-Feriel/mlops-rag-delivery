{
  "uid": "hd-per-service",
  "title": "Hello Delivery — Per-Service Activity (v3)",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "tags": ["livraison", "simulator", "v3"],
  "templating": {
    "list": [
      {
        "name": "source_service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(sim_events_total, source_service)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      },
      {
        "name": "topic",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(sim_events_total, topic)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Simulator status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STOPPED", "color": "red" }, "1": { "text": "RUNNING", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [ { "expr": "sim_running", "refId": "A" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events/sec — total",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 2, "unit": "ops" } },
      "targets": [ { "expr": "sum(rate(sim_events_total[1m]))", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Commandes simulées (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "expr": "sum(sim_commandes_total)", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Taux annulation (5min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 2, "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum(rate(sim_commandes_total{destin=\"annulee\"}[5m])) / clamp_min(sum(rate(sim_commandes_total[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Events/sec par service (source_service)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (source_service) (rate(sim_events_total{source_service=~\"$source_service\"}[1m]))",
          "legendFormat": "{{source_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Events/sec par topic Kafka",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (topic) (rate(sim_events_total{topic=~\"$topic\"}[1m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "type": "bargauge",
      "title": "Events totaux par service (cumulé)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        {
          "expr": "sum by (source_service) (sim_events_total)",
          "legendFormat": "{{source_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "piechart",
      "title": "Destin des commandes (livrée / annulée / échouée)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "targets": [
        {
          "expr": "sum by (destin) (sim_commandes_total)",
          "legendFormat": "{{destin}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "Top 10 event_type par fréquence (5min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] } },
      "targets": [
        {
          "expr": "topk(10, sum by (event_type) (rate(sim_events_total[5m])))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 40,
      "type": "row",
      "title": "RAG Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "RAG query latency (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(rag_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "RAG retrieval score moyen + active requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "targets": [
        { "expr": "rag_context_score_avg", "legendFormat": "context score avg", "refId": "A" },
        { "expr": "rag_active_requests", "legendFormat": "active requests", "refId": "B" }
      ]
    }
  ]
}
